# ──────────────────────────────────────────────
# Smart Return Furor — Environment Variables
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────

# Shopify Partners App credentials
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here

# Your deployed Railway URL (no trailing slash)
HOST=https://your-app-name.railway.app

# OAuth scopes (comma-separated, no spaces)
SCOPES=read_orders,write_orders,read_products

# Server port (Railway sets this automatically)
PORT=3000

# Node environment
NODE_ENV=production
